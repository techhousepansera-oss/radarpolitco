# BOW 360 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus dados reais

# Supabase — encontre em: supabase.com → seu projeto → Project Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# n8n Webhook — URL do trigger no seu workflow
VITE_N8N_WEBHOOK_URL=https://seu-n8n.dominio.com/webhook/seu-webhook-id
